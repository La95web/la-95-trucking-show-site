---
const { navTips1, navTips2, navTips3, navTips4, navTips5, link1, link2, link3, link4, link5 } = Astro.props;
---
<div class="section">
  <nav>
    <ul>
      <li><a href={link1}>{navTips1}</a></li>
      <li><a href={link2}>{navTips2}</a></li>
      <li><a href={link3}>{navTips3}</a></li>
      <li><a href={link4}>{navTips4}</a></li>
      <li><a href={link5}>{navTips5}</a></li>
    </ul>
  </nav>
</div>

<div class="main-container">
	<div class="info-column">
		<h1 class="main-title">
			<span class="title-part-1">CURSO ESENCIAL</span>
			<span class="title-part-2">PARA CAMIONEROS</span>
		</h1>
		<div class="icon-grid">
			<div class="icon-box">
				<svg class="icon-svg" viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
				<span class="icon-box-title">PROTEGE TU CDL</span>
			</div>
			<div class="icon-box">
				<svg class="icon-svg" viewBox="0 0 24 24"><path d="M21 5c-1.11-.35-2.33-.5-3.5-.5-1.95 0-4.05.4-5.5 1.5-1.45-1.1-3.55-1.5-5.5-1.5S2.45 4.9 1 6v14.65c0 .25.25.5.5.5.1 0 .15-.05.25-.05C3.1 20.45 5.05 20 6.5 20c1.95 0 4.05.4 5.5 1.5 1.35-.85 3.1-1.5 5.5-1.5 1.65 0 3.35.3 4.75 1.05.1.05.15.05.25.05.25 0 .5-.25.5-.5V6c-.6-.45-1.25-.75-2-1zm0 13.5c-1.1-.35-2.3-.5-3.5-.5-1.7 0-3.45.3-5 1V7.5c1.55-.7 3.3-1 5-1 1.2 0 2.4.15 3.5.5v11.5z"/></svg>
				<span class="icon-box-title">APRENDE A TU RITMO</span>
			</div>
			<div class="icon-box">
				<svg class="icon-svg" viewBox="0 0 24 24"><path d="M19 3h-4.18C14.4 1.84 13.3 1 12 1s-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm1 13H7v-2h6v2zm3-4H7v-2h9v2zm0-4H7V7h9v2z"/></svg>
				<span class="icon-box-title">TEMAS CLAVE</span>
			</div>
			<div class="icon-box">
				<svg class="icon-svg" viewBox="0 0 24 24" fill="currentColor">
					<path d="M12 2C7.03 2 3 6.03 3 11v1c0 .55.45 1 1 1h1v-2c0-3.87 3.13-7 7-7s7 3.13 7 7v2h1c.55 0 1-.45 1-1v-1c0-4.97-4.03-9-9-9zm-7 8c-.83 0-1.5.67-1.5 1.5v3c0 .83.67 1.5 1.5 1.5S6.5 15.33 6.5 14.5v-3c0-.83-.67-1.5-1.5-1.5zm14 0c-.83 0-1.5.67-1.5 1.5v3c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5v-3c0-.83-.67-1.5-1.5-1.5zM12 6c-2.76 0-5 2.24-5 5s2.24 5 5 5 5-2.24 5-5-2.24-5-5-5zm6.5 9.5c0 2.48-2.02 4.5-4.5 4.5h-2v2h2c3.59 0 6.5-2.91 6.5-6.5v-.5h-2v.5z" /></svg>
				<span class="icon-box-title">APOYO REAL PARA TI</span>
			</div>
		</div>

		<div class="bottom-banner">
			<div class="banner-item">
				<svg class="banner-icon" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
				CONTENIDO 100% PRÁCTICO
			</div>
			<div class="banner-item">
				<svg class="banner-icon" viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/><path d="M12.5 7H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
				ACCEDE CUANDO Y DONDE QUIERAS
			</div>
			<div class="banner-item">
				<svg class="banner-icon" viewBox="0 0 24 24"><path d="M22 18H2v2h20v-2zM4 14V3h16v11H4zm2-2h12V5H6v7z"/></svg>
				DESDE CUALQUIER DISPOSITIVO
			</div>
		</div>
	</div>

	<form class="form-column">
		<div class="form-header">
			<svg class="header-icon" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/></svg>
			<div class="header-text">
				<h2>REGÍSTRATE AHORA</h2>
				<p>Y DA EL PRIMER PASO PARA ESTAR READY</p>
			</div>
		</div>

		<div class="input-group">
			<svg class="input-icon" viewBox="0 0 24 24"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
			<input type="text" class="form-input" placeholder="Nombre completo">
		</div>

		<div class="input-group">
			<svg class="input-icon" viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
			<input type="email" class="form-input" placeholder="Correo electrónico">
		</div>

		<div class="input-group">
			<svg class="input-icon" viewBox="0 0 24 24"><path d="M20.01 15.38l-2.33-1.3c-.38-.21-.86-.15-1.18.17l-1.39 1.39c-2.12-1.1-3.8-2.78-4.9-4.9l1.39-1.39c.32-.32.38-.8.17-1.18l-1.3-2.33c-.24-.44-.73-.72-1.23-.72H7.6c-.63 0-1.16.51-1.18 1.15-.08 1.48.24 2.92.93 4.22.78 1.48 1.94 2.76 3.42 3.54 1.3.69 2.74 1.01 4.22.93.64-.02 1.15-.55 1.15-1.18v-2.31c0-.5-.28-.99-.72-1.23zM16 6h2v2h-2zm0-2h2v2h-2zm-2 2h2v2h-2zm-2-2h2v2h-2z"/></svg>
			<input type="tel" class="form-input" placeholder="Teléfono">
		</div>

		<div class="input-group">
			<svg class="input-icon" viewBox="0 0 24 24"><path d="M20 8h-3V4c0-1.1-.9-2-2-2H9c-1.1 0-2 .9-2 2v4H4c-1.1 0-2 .9-2 2v10h1v2h1v-2h14v2h1v-2h1V10c0-1.1-.9-2-2-2zM9 4h6v4H9V4zm11 14H4v-8h16v8zm-2-2h-3v-3h-2v3H9v-3H7v3H6v-5h12v5z"/></svg>
			<select class="form-select">
				<option value="" disabled selected>¿Tienes tu CDL?</option>
				<option value="si">Sí</option>
				<option value="no">No</option>
			</select>
		</div>

		<div class="input-group">
			<svg class="input-icon" viewBox="0 0 24 24"><path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM7 10h5v5H7z"/></svg>
			<select class="form-select">
				<option value="" disabled selected>¿Cuánto tiempo llevas manejando?</option>
				<option value="0-1">Menos de 1 año</option>
				<option value="1-3">1-3 años</option>
				<option value="3-5">3-5 años</option>
				<option value="5+">Más de 5 años</option>
			</select>
		</div>

		<button type="submit" class="submit-button">
			QUIERO REGISTRARME
			<svg class="button-arrow" viewBox="0 0 24 24"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6-1.41-1.41z"/></svg>
		</button>

		<div class="form-footer">
			<svg class="footer-lock-icon" viewBox="0 0 24 24"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zM9 8V6c0-1.66 1.34-3 3-3s3 1.34 3 3v2H9z"/></svg>
			Tu información está segura y no será compartida.
		</div>
	</form>
</div>

<style lang="scss">
  @use '../assets/sass/index' as *;
  /* Estilos Globales y Reset */
  :root {
		--bg-dark: #11141a; 
		--bg-form: #1c212a; 
		--gold: #ffc107;    
		--white: #ffffff;
		--font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
		--blue-glow: rgba(59, 130, 246, 0.5); 
  }

  body, h1, h2, h3, p, ul, form, input, select, button {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
  }

body {
  min-height: 100vh;
  position: relative;
  /* Evitamos desbordamientos no deseados */
  overflow-x: hidden;
}

/* Fondo fijo simulado con alto de viewport estable */
body::before {
  content: "";
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  /* Usamos height: 100dvh para navegadores modernos o 100vh estable */
  height: 100dvh; 
  z-index: -1;

  background-image: url("../assets/image/carretera.webp");
  background-size: cover;
  background-position: center;
  background-repeat: no-repeat;

  /* IMPORTANTE: Evita recalcular o distorsionar al hacer scroll */
  will-change: transform;
  pointer-events: none;
}

  nav ul{
    display: flex;
    flex-direction: row;
    justify-content: center;
    flex-wrap: wrap;
  }

  .section {
    display: flex;
    flex-direction: column;
    background-color: $primary;
  }

   ul{
    font-family: $text;
    font-size: 1.2rem;
    line-height: 2.5;
    font-weight: $regular;
    color: white;
    padding: 0;
  }

  i{
    color: $accent-b-dark;
    margin: 10px;
  }

  li {
    margin: 10px;
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;

    li {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      margin-bottom: 12px;
      font-family: $text;
      font-size: 16px;
      line-height: 1.5;
      color: white;

      i {
        font-size: 20px;
        color: #FFCC4D;
        flex-shrink: 0;
        margin-top: 4px;
      }

      span {
        display: block;
        flex: 1;
      }
    }
  }

  a{
    font-size: 1.2rem;
    color: $secondary;
  }

  .main-container {
		display: grid;
		grid-template-columns: 1fr; 
		gap: 2rem;
		max-width: 1200px;
		margin: 0 auto;
		padding: 2rem;
		align-items: start;
  }

  .info-column {
		order: 1; 
  }

.main-title {
  display: flex;
  flex-direction: column;
  font-size: 2.5rem;
  text-transform: uppercase;
  font-weight: 800;
  margin-bottom: 2rem;
  text-align: center;
  line-height: 0.95;
  position: relative;
  padding-bottom: 12px;
}

.main-title::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 3px; 
  background: linear-gradient(to right, var(--gold) 0%, rgba(0, 0, 0, 0) 100%);
  border-radius: 2px;
}

  .title-part-1 { color: var(--white); font-style: italic; }
  .title-part-2 { color: var(--gold); font-style: italic; }

  /* Cuadrícula de Iconos (GRID para 2x2 en móvil, 4x1 en escritorio) */
  .icon-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
		margin-bottom: 2rem;
  }

  .icon-box {
		background-color: rgba(28, 33, 42, 0.4);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 8px;
		padding: 1.5rem;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		transition: transform 0.3s ease;
  }

  .icon-box:hover {
		transform: translateY(-5px);
		background-color: rgba(28, 33, 42, 0.6);
  }

  .icon-svg {
		width: 50px;
		height: 50px;
		margin-bottom: 1rem;
  }

  .icon-box-title {
		text-transform: uppercase;
		font-size: 0.9rem;
		color: var(--white);
		font-weight: bold;
  }

  .icon-box:first-child .icon-svg { fill: var(--gold); } /* Escudo dorado */
  .icon-box:not(:first-child) .icon-svg { fill: var(--white); } /* El resto blancos */
  .icon-box:first-child .icon-box-title { color: var(--gold); } /* Título dorado en el primero */

  /* Barra Inferior (FLEX para los tres elementos) */
  .bottom-banner {
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		background-color: #0b111a;
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 8px;
		padding: 1rem;
		gap: 1rem;
  }

  .banner-item {
		display: flex;
		align-items: center;
		gap: 10px;
		color: var(--gold);
		font-size: 0.8rem;
		font-weight: bold;
		text-transform: uppercase;
  }

  .banner-icon {
		width: 24px;
		height: 24px;
		fill: var(--gold);
  }

  /* --- Estilos de la Columna Derecha (Formulario) --- */
  .form-column {
		order: 2; /* Esto asegura que aparezca de segundo en móvil */
		background-color: var(--bg-form);
		border-radius: 12px;
		padding: 2rem;
		box-shadow: 0 4px 10px rgba(0,0,0,0.5);
		position: relative;
		overflow: hidden;
		border: 1px solid rgba(255, 255, 255, 0.1);
  }

  /* Resplandor superior azul */
  .form-column::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 5px;
		background: linear-gradient(90deg, transparent, var(--blue-glow) 50%, transparent);
		filter: blur(2px);
  }

  .form-header {
		display: flex;
		align-items: flex-start;
		gap: 15px;
		margin-bottom: 2rem;
  }

  .header-icon {
		width: 32px;
		height: 32px;
		fill: var(--gold);
		flex-shrink: 0;
  }

  .header-text h2 {
		font-size: 1.5rem;
		color: var(--gold);
		text-transform: uppercase;
		font-weight: bold;
  }

  .header-text p {
		font-size: 0.85rem;
		color: var(--white);
		text-transform: uppercase;
  }

  /* Campos de Entrada (Estilos Comunes) */
  .input-group {
		position: relative;
		margin-bottom: 1rem;
  }

  .input-icon {
		position: absolute;
		left: 15px;
		top: 50%;
		transform: translateY(-50%);
		width: 18px;
		height: 18px;
		fill: #777;
  }

  .form-input, .form-select {
		width: 100%;
		padding: 12px 12px 12px 45px;
		background-color: #242932;
		border: 1px solid rgba(255, 255, 255, 0.1);
		color: var(--white);
		font-size: 0.9rem;
		border-radius: 6px;
		outline: none;
		transition: border-color 0.3s;
  }

  .form-select {
		appearance: none;
		background-image: url('data:image/svg+xml;charset=UTF-8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white"><path d="M7 10l5 5 5-5H7z"/></svg>');
		background-repeat: no-repeat;
		background-position: right 10px center;
		background-size: 16px;
  }

  .form-input::placeholder {
		color: #777;
  }

  .form-input:focus, .form-select:focus {
		border-color: var(--blue-glow);
  }

  /* Botón de Registro */
  .submit-button {
		width: 100%;
		padding: 15px;
		background: linear-gradient(180deg, #ffca2c 0%, var(--gold) 100%);
		border: none;
		border-radius: 6px;
		color: #000;
		font-size: 1rem;
		font-weight: bold;
		text-transform: uppercase;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		cursor: pointer;
		transition: background 0.3s, transform 0.2s;
		margin-top: 1rem;
		margin-bottom: 1rem;
  }

  .submit-button:hover {
    background: #e0ac00;
  }

  .submit-button:active {
    transform: scale(0.98);
  }

  .button-arrow {
		width: 16px;
		height: 16px;
		fill: #000;
  }

  /* Pie del Formulario */
  .form-footer {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		font-size: 0.7rem;
		color: #777;
		text-align: center;
  }

  .footer-lock-icon {
		width: 12px;
		height: 12px;
		fill: #777;
  }

  /* --- Media Queries --- */
  @media (min-width: 1024px) {
    .main-container {
			grid-template-columns: 2fr 1fr; 
			padding: 4rem 2rem;
			align-items: center;
    }

    .info-column {
			order: 1; 
			padding-right: 2rem;
    }

    .form-column {
      order: 2;
    }

    .main-title {
			text-align: left;
			font-size: 3rem;
    }

    .icon-grid {
			grid-template-columns: repeat(4, 1fr); /* 4 iconos en una fila */
			gap: 1rem;
    }
    
    .icon-box {
      padding: 1.5rem 1rem;
    }

    .bottom-banner {
			flex-direction: row;
      padding: 1.5rem;
    }
    
    .section {
      flex-direction: column;
      align-items: center;
      text-align: center;
      justify-content: space-between;
      
      h2 {
        font-size: 3rem;
      }
      p {
        font-size: 1.25rem;
      }
    }
    
    ul {
      gap: 50px;
      margin: 0;
    }
    
    a{
      font-size: 2.5rem;
      color: white;
    }
    
    nav {
      margin: 0 15%;
    }

    .title-part-1 { color: var(--white); font-size: 5rem; }
    .title-part-2 { color: var(--gold); font-size: 5rem;  }
  }
      
  /* Tableta (Adaptación) */
  @media (min-width: 768px) and (max-width: 1023px) {
		.main-title {
			font-size: 2.8rem;
		}
		
		.icon-grid {
			grid-template-columns: repeat(2, 1fr);
			gap: 1.5rem;
		}
  }
</style>