---
import TrafficLight from "../components/TrafficLight.astro";
import Navigation from "../components/Navigation.astro";
import favicon from "../assets/image/logo4.png";
const {
  title,
  ogTitle,
  ogDescription,
  ogImage,
  ogUrl
} = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
    <link rel="icon" type="image/png" href={favicon.src} />
    <link rel="canonical" href={ogUrl} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} /> 
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="La 95 Trucking Show" />
    <meta property="og:title" content={ogTitle || title} />
    <meta property="og:description" content={ogDescription || "La 95 Trucking Show"} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content="Plataforma para camioneros con servicios, descuentos y suscripciones" />
    <meta property="og:url" content={ogUrl} />

    <!-- WhatsApp / Facebook -->
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
		<title>{title}</title>
    <!-- <script src="https://sandbox.web.squarecdn.com/v1/square.js"></script> -->
		<script src="https://unpkg.com/@phosphor-icons/web"></script>
	</head>
  <body>
    <TrafficLight />
    <Navigation />
    <slot />
  </body>
</html>

<style is:global lang="scss">
  @use '../assets/sass/index' as *; 
    
  html {
    scroll-behavior: smooth;
  }
  
  li, ol, a {
    list-style: none;
    text-decoration: none;
  }
  
  body {
    background-color: $tertiary;
    font-size: 16px;
    margin: 0;
    padding: 0;
  }
  
  * {
    box-sizing: border-box;
  }
  
  h1, h3 {
    font-size: 2rem;
    font-weight: $regular;
    font-family: $heading;
    color: $secondary;
    margin: 0 5%;
  }

  h2 {
    font-size: 2rem;
    font-weight: $regular;
    font-family: $heading;
    color: $secondary;
    margin: 0 5%;
  }
  
  .underline {
    width: 130px;
    height: 2px;
    background-color: $accent-b-dark;
    justify-content: left;
    margin-top: 0px;
    border-radius: 2px;
    margin: 0 5%; 
  }
  
  p {
    font-size: 1.25rem;
    font-family: $text;
    font-weight: $regular;
    color: $secondary;
  }

  .lead-paragraph a {
    color: $accent-b-dark;
    text-decoration: underline;
    word-break: break-word;
  }
  
  .lead-paragraph {
    white-space: pre-line;
    margin-top: 20px;
  }

  .extra-content a {
    color: $accent-b-dark;
    text-decoration: underline;
    word-break: break-word;
  }

  .article-wrapper {
    display: flex;
    flex-direction: column;
  }

  .extra-content {
    width: 100%;
    white-space: pre-line;
    opacity: 0;
    max-height: 0;
    overflow: hidden;
    transition: all 0.4s ease;
  }

  .extra-content.active {
    opacity: 1;
    max-height: 2000px;
    margin-top: 0;
  }

  .article-content {
    position: relative;
    max-width: 100%;
  }
  
  // inicia boton rojo de accion
  
  .light-button {
    width: 145px; 
    height: 40px;
    border-radius: 8px;
    margin: 30px 5% 30px;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: background-color 0.3s, box-shadow 0.3s;
    cursor: pointer;
  }
  
  a {
    color: $primary;
    font-size: 1.5rem;
    font-weight: $regular;
    font-family: $heading;
  }

  button {
    border: none;
  }
  
  .light-button.red-button {
    background-color: $accent-c-dark;
    box-shadow: 0 0 20px 10px rgba($accent-c-dark, 35%);
  }
  
  .red-button {
    background-color: $accent-c-light;
  }
  
  .light-button:hover {
    background-color: $accent-c-light;
    box-shadow: 0 0 25px 15px rgba($accent-c-light, 40%);
  }

  // cart 

  #cart-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0;
  }

  .cart-item {
    display: block;
    background-color: $tertiary;
    width: 90%;
    padding: 15px;

    p {
      margin: 0 2%;
    }
  }

  .cart-item:nth-child(even) {
    background-color: $primary;
  }

  .flex-container {
    display: flex;
    position: relative;
    justify-content:space-between;
    cursor: pointer;
    
    button {
      background-color: transparent;
    }
  }

  .trash img {
    position: absolute;
    left: 70px;
    width: 32px;
    top: 30px;
  }

  .button-section {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 29px;
    border: 2px solid $accent-b-dark;
    border-radius: 15px;
    margin: 20px 2% 0;
    position: relative;
    width: 130px;
    
    span {
      font-size: 1rem;
      font-family: $text;
      font-weight: $medium;
    }
    img {
      display: flex;
      width: 18px;
      height: 18px;
      cursor: pointer;
    }
  }

  .button-section::before,
  .button-section::after {
    content: '';
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2px;
    background-color: $accent-b-dark; 
  }

  .button-section::before {
    left: 35px; 
  }

  .button-section::after {
    right: 35px; 
  }

  .simbol-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    
    p{
     margin: 10px 0 0;
    }
  }

  .trash {
    position: absolute;
    left: 25%;
  }

  //comment form

  .comment {

    &:last-child {
      border-bottom: none;
    }

    strong {
      display: block;
      font-size: 18px;
      margin-bottom: 5px;
      color: white;
    }

    em {
      font-size: 14px;
      color: white;
      margin-bottom: 10px;
      display: block;
    }

    p {
      font-size: 16px;
      line-height: 1.5;
      color: white;
    }
  }
  //reactions
    .reactions {
      display: flex;
      gap: 5px;
      padding-bottom:20px ;
      span {
        color: white;
      }
    }

  .reaction {
    background: none;
    border: none;
    font-size: 18px;
    cursor: pointer;
    transition: transform 0.2s ease;
  }

  // boton autentication
  .user-info-box {
    margin: 20px auto;        /* centrado automático */
    padding: 12px 18px;
    background: #f7f7f7;
    border-radius: 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 15px;
    border: 1px solid #e0e0e0;
    max-width: 600px;         /* 👈 controla el ancho máximo */
    width: 90%; 
  }

  /* Texto */
  .user-info-box p {
    margin: 0;
    font-size: 1rem;
    color: #333;
  }

  /* Botón profesional */
  .logout-btn {
    background: linear-gradient(135deg, #ff4d4d, #d93636);
    border: none;
    padding: 10px 18px;
    border-radius: 8px;
    color: white;
    font-weight: 600;
    cursor: pointer;
    transition: 0.2s ease-in-out;
    box-shadow: 0 3px 6px rgba(0,0,0,0.15);
  }

  /* Hover */
  .logout-btn:hover {
    background: linear-gradient(135deg, #ff6666, #e64545);
    transform: translateY(-2px);
  }

  /* Active */
  .logout-btn:active {
    transform: scale(0.97);
}

  .reaction:hover {
    transform: scale(1.2);
  }

  // botón de eliminar comentario
  .delete-comment {
    background: transparent;
    color: #a94442;
    border: 1px solid #f5c6cb;
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 0.85rem;
    cursor: pointer;
    margin-top: 10px;
    transition: all 0.2s ease-in-out;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  /* Hover */
  .delete-comment:hover {
    background: #f5c6cb;
    color: #8a1f1f;
    transform: translateY(-2px);
    box-shadow: 0 2px 6px rgba(0,0,0,0.15);
  }

  /* Active */
  .delete-comment:active {
    transform: scale(0.97);
  }

  @media (min-width: 1024px) {

    .extra-content.active {
      opacity: 1;
      max-height: 2000px;
      margin-top: 40px;
    }

    .cart-item {
      display: grid;
      grid-template-columns: 2fr 4fr auto;
      justify-content: space-between;
      align-items: center;
    }

    .trash {
      position: absolute;
      left: 150px;
    }

    h2{
      font-size: 3rem;
    }
  }
</style>
